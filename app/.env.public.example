API_PORT=4310
ENABLE_CLIPBOARD_MONITOR=true

# Leave empty for same-origin deploy (recommended with reverse proxy).
VITE_API_BASE=

# Comma-separated viewer web origins.
# Local-only default (safe for current dev machine):
PUBLIC_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Public deploy example:
# PUBLIC_ALLOWED_ORIGINS=https://your-domain.com

# Keep false unless you run behind a trusted reverse proxy
# and want per-client rate-limit bucketing from x-forwarded-for.
TRUST_PROXY_FOR_RATE_LIMIT=false
